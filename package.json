{
  "name": "memo-app",
  "version": "1.0.0",
  "description": "Folder-based markdown memo app",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && electron-builder --win zip",
    "start": "electron ."
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.2.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@uiw/react-codemirror": "^4.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.memoapp.app",
    "productName": "MemoApp",
    "asar": true,
    "files": ["main.js", "preload.js", "dist/**", "node_modules/**"],
    "win": {
      "sign": null,
      "target": [{ "target": "zip", "arch": ["x64"] }]
    }
  }
}
